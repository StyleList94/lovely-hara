{
  "name": "lovely-hara",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "sh scripts/install-motion-plus.sh",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "lint": "oxlint && eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "format": "oxfmt . && prettier --write '**/*.astro'",
    "format:check": "oxfmt --check . && prettier --check '**/*.astro'",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "astro build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.1.4",
    "@astrojs/react": "5.0.2",
    "@stylelist94/nine-beauty-actress": "^2.1.1",
    "astro": "6.1.1",
    "bignumber.js": "^10.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jimp": "^1.6.0",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^5.2.0",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^9.39.2",
    "eslint-config-stylish": "^3.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
